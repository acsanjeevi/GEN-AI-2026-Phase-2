					"name": "20 - Create Test Execution - Testleaf",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"scriptId\": \"leaftaps-create-lead\",\n    \"featureContent\": \"Feature: Create Lead in Leaftaps Application\\n  @smoke @createLead\\n  Scenario: Verify user can create a new lead successfully\\n    Given I navigate to Leaftaps application\\n    When I enter username as \\\"Democsr\\\"\\n    And I enter password as \\\"crmsfa\\\"\\n    And I click the login button\\n    When I click on the \\\"CRM\\/SFA\\\" link\\n    And I click on the \\\"Leads\\\" tab\\n    And I click on the \\\"Create Lead\\\" link right side maincontainer focus should be main container\\n    When I enter the Company Name as \\\"TestLeaf\\\" on rightside panel\\n    And I enter the First name as \\\"Sankar\\\" on rightside panel\\n    And I enter the Last name as \\\"Govindharaj\\\" on rightside panel\\n    And I select the Source as \\\"Employee\\\" on rightside panel\\n    And I select the Marketing Campaign as \\\"Automobile\\\" on rightside panel\\n    And I click the Create Lead button on rightside panel\\n    And I wait for 3 seconds\\n    And I click on the \\\"Govindharaj\\\" link\\n    And I wait for 2 seconds\\n    Then the page should contain \\\"Assigned\\\"\",\n    \"baseUrl\": \"http://leaftaps.com/opentaps\",\n    \"name\": \"Create Lead - Leaftaps\",\n    \"browser\": {\n        \"type\": \"chromium\",\n        \"headless\": false\n    },\n    \"options\": {\n        \"maxRetries\": 1,\n        \"timeout\": 300000,\n        \"screenshotOnFailure\": true,\n        \"recordVideo\": true,\n        \"traceEnabled\": true\n    }\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},

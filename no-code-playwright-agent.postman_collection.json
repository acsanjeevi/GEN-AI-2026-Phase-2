							"raw": "{\n    \"scriptId\": \"redbus-search-buses\",\n    \"featureContent\": \"Feature: Search for buses in RedBus\\n\\n  Scenario: Search buses from Chennai to Bangalore on today's date\\n    Given I launch the RedBus website\\n    When I click the \\\"From\\\" field\\n   And I click the first suggested match for \\\"Chennai\\\"\\n    And I click the \\\"To\\\" field\\n     And I click the first suggested match for \\\"Bangalore\\\"\\n  And I click the \\\"Search Buses\\\" button\\n    Then I should see a list of available buses\\n When I click on the first matching 'View seats for ..' button in the Search results section\\n Then I should see Lower deck text on the page\\n When I click on the Boarding Point\\n Then I should see View all boarding points button\",\n    \"baseUrl\": \"https://www.redbus.in/\",\n    \"name\": \"Search Bus\",\n    \"browser\": {\n        \"type\": \"chromium\",\n        \"headless\": false\n    },\n    \"options\": {\n        \"maxRetries\": 2,\n        \"timeout\": 30000,\n        \"screenshotOnFailure\": true,\n        \"recordVideo\": true,\n        \"traceEnabled\": true\n    }\n}",
